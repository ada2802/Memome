# MemoMe v2 — copy this to .env and edit as needed

# ── Whisper model ────────────────────────────────────────────────
# tiny   ~40MB  fastest,  rough quality  — good for testing
# base   ~75MB  fast,     decent quality — recommended start
# small  ~244MB moderate, good quality
# distil-large-v3  ~756MB  best quality (needs ~2GB RAM on CPU)
#WHISPER_MODEL=base
WHISPER_MODEL=large-v3-turbo

# ── Ollama ───────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
# qwen2.5:3b  ~2GB RAM, faster translations, slightly lower quality
# qwen2.5:7b  ~5GB RAM, better translations (default)
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT=45

# ── VAD sensitivity ──────────────────────────────────────────────
# Lower = picks up quieter speech, also more background noise
# Higher = only transcribes louder speech
VAD_THRESHOLD=0.015

# Set SILERO=1 to use Silero VAD (requires torch installed)
# Better accuracy in noisy environments
SILERO=0

# ── Audio processing ─────────────────────────────────────────────
# Seconds of silence before flushing speech buffer to Whisper
SILENCE_FLUSH_SEC=1.2
# Hard cap: always flush after this many seconds even without silence
MAX_SPEECH_SEC=30.0

# ── Voice quality tuning (new) ───────────────────────────────────
# Overlap context prepended to each speech segment (seconds).
# Catches words at the start of a new speech burst.
# Higher = better boundary coverage, slightly more Whisper work.
OVERLAP_SEC=0.5

# Minimum speech segment duration before sending to Whisper.
# Clips shorter than this are skipped (avoid hallucinations on noise pops).
MIN_SPEECH_SEC=0.6

# Silence padding added before/after each segment.
# Gives Whisper a moment to "warm up" before the first word.
PAD_SEC=0.25

# Energy VAD sensitivity (lower = more sensitive to quiet speech).
# If you still miss speech, try 0.005.  If too much noise, try 0.012.
VAD_THRESHOLD=0.008

# ── Whisper language override ────────────────────────────────
# Leave blank (default) = Whisper auto-detects the spoken language
# each chunk and outputs text in that language.
#
# Set to a language code to SKIP detection and always transcribe
# in that language — faster (~100ms/chunk saved) but no multilingual:
#   en = English only
#   zh = Chinese only
#   ja = Japanese only
#   (see https://github.com/openai/whisper#available-models-and-languages)
#
# NOTE: Do NOT set this when speakers switch languages — auto-detect
# is the correct mode for multilingual meetings.
WHISPER_LANG=
